# Copy to .env and fill in the blanks. Never commit the real .env.
# In production this lives at /var/www/ecomist/.env (chmod 600, owner www-data);
# restart the service after editing: sudo systemctl restart ecomist

# --- Server ---
PORT=8995
# LISTEN_ADDR overrides PORT entirely if set (default 127.0.0.1:$PORT)
#LISTEN_ADDR=127.0.0.1:8995
DB_PATH=ecomist.db
BASE_URL=https://ecomist.mchugh.au
TZ=Australia/Melbourne

# --- Local development only ---
# DEV_MODE=1 enables GET /dev/login (instant admin sign-in, no email needed)
# and shows verification links on-screen when SMTP is not configured.
#DEV_MODE=1

# --- The cross-franchise administrator ---
# This address may register even though it is not @ecomist.com.au, and is
# promoted to admin automatically on first verified login.
ADMIN_EMAIL=james67@gmail.com

# --- Outbound email for verification links ---
# Leave SMTP_HOST empty to skip sending: links are logged (journalctl -u ecomist)
# instead of emailed. For Gmail: create an app password at
# https://myaccount.google.com/apppasswords (needs 2-Step Verification)
# and paste it WITHOUT spaces.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=james67@gmail.com
SMTP_PASS=
# From address; defaults to SMTP_USER when blank
EMAIL_FROM=james67@gmail.com

# --- PDF run-sheet import (optional; feature hides itself when blank) ---
ANTHROPIC_API_KEY=
